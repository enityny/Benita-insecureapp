<%- include('partials/header') %>
  <section class="hero-section d-flex align-items-center">
    <div class="container text-center text-white">
      <h1 class="display-3 fw-bold mb-3">Discover Your Style</h1>
      <p class="lead mb-4">Premium fashion curated for the modern individual</p>
      <a href="/shop" class="btn btn-light btn-lg px-5 fw-bold">Shop Now</a>
    </div>
  </section>

  <section class="container my-5">
    <div class="text-center mb-5">
      <h2 class="fw-bold">Featured Collection</h2>
      <p class="text-muted">Handpicked pieces for this season</p>
    </div>
    <div class="row g-4">
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>
          <div class="col-lg-3 col-md-6">
            <div class="card product-card h-100 border-0 shadow-sm">
              <div class="product-img-wrapper">
                <img src="<%= product.image || '/uploads/placeholder.jpg' %>" class="card-img-top" alt="<%= product.name %>">
                <div class="product-overlay">
                  <a href="/product?id=<%= product.id %>" class="btn btn-sm btn-light">View Details</a>
                </div>
              </div>
              <div class="card-body text-center">
                <h6 class="fw-bold mb-1"><%= product.name %></h6>
                <p class="text-muted small mb-2">KSh <%= Number(product.price).toLocaleString() %></p>
                <span class="badge bg-secondary"><%= product.category %></span>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-12 text-center py-5">
          <i class="bi bi-box-seam display-1 text-muted"></i>
          <p class="text-muted mt-3">No products available yet</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="bg-light py-5">
    <div class="container text-center">
      <div class="row g-4">
        <div class="col-md-4">
          <div class="p-4">
            <i class="bi bi-truck display-5 text-dark"></i>
            <h5 class="fw-bold mt-3">Free Delivery</h5>
            <p class="text-muted small">On orders above KSh 5,000</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-4">
            <i class="bi bi-shield-check display-5 text-dark"></i>
            <h5 class="fw-bold mt-3">Secure Payment</h5>
            <p class="text-muted small">100% secure transactions</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-4">
            <i class="bi bi-arrow-return-left display-5 text-dark"></i>
            <h5 class="fw-bold mt-3">Easy Returns</h5>
            <p class="text-muted small">30-day return policy</p>
          </div>
        </div>
      </div>
    </div>
  </section>
<%- include('partials/footer') %>
