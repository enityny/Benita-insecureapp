<%- include('partials/header') %>
<div class="container py-5">
  <div class="row">
    <div class="col-lg-3">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
          <h5 class="fw-bold mb-3">Categories</h5>
          <ul class="list-unstyled">
            <li class="mb-2"><a href="/shop" class="text-decoration-none text-dark">All</a></li>
            <% if (categories) { %>
              <% categories.forEach(cat => { %>
                <li class="mb-2">
                  <a href="/shop?category=<%= cat.category %>" class="text-decoration-none text-dark">
                    <i class="bi bi-dot me-1"></i><%= cat.category.charAt(0).toUpperCase() + cat.category.slice(1) %>
                  </a>
                </li>
              <% }) %>
            <% } %>
          </ul>
        </div>
      </div>
    </div>
    <div class="col-lg-9">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">Our Collection</h3>
        <span class="text-muted"><%= products ? products.length : 0 %> items</span>
      </div>
      <div class="row g-4">
        <% if (products && products.length > 0) { %>
          <% products.forEach(product => { %>
            <div class="col-md-4 col-6">
              <div class="card product-card h-100 border-0 shadow-sm">
                <div class="product-img-wrapper">
                  <img src="<%= product.image || '/uploads/placeholder.jpg' %>" class="card-img-top" alt="<%= product.name %>">
                  <div class="product-overlay">
                    <a href="/product?id=<%= product.id %>" class="btn btn-sm btn-dark">Quick View</a>
                  </div>
                </div>
                <div class="card-body">
                  <h6 class="fw-bold mb-1"><%= product.name %></h6>
                  <p class="text-muted small mb-2">KSh <%= Number(product.price).toLocaleString() %></p>
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="badge bg-light text-dark"><%= product.category %></span>
                    <% if (product.stock > 0) { %>
                      <span class="badge bg-success">In Stock</span>
                    <% } else { %>
                      <span class="badge bg-danger">Out of Stock</span>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12 text-center py-5">
            <i class="bi bi-search display-1 text-muted"></i>
            <p class="text-muted mt-3">No products found</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
