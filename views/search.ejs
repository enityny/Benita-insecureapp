<%- include('partials/header') %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="text-center mb-5">
        <h3 class="fw-bold"><i class="bi bi-search me-2"></i>Search Products</h3>
        <p class="text-muted">Find your perfect fashion piece</p>
      </div>
      <form class="mb-5" method="GET" action="/search">
        <div class="input-group input-group-lg">
          <input type="text" name="q" class="form-control" placeholder="Search by name or description..." value="<%= query || '' %>">
          <button type="submit" class="btn btn-dark px-4"><i class="bi bi-search"></i></button>
        </div>
      </form>

      <% if (query) { %>
        <p class="text-muted mb-3">Showing results for: <strong><%= query %></strong></p>
      <% } %>

      <div class="row g-4">
        <% if (results && results.length > 0) { %>
          <% results.forEach(product => { %>
            <div class="col-md-4 col-6">
              <div class="card product-card h-100 border-0 shadow-sm">
                <div class="product-img-wrapper">
                  <img src="<%= product.image || '/uploads/placeholder.jpg' %>" class="card-img-top" alt="<%= product.name %>">
                  <div class="product-overlay">
                    <a href="/product?id=<%= product.id %>" class="btn btn-sm btn-dark">View</a>
                  </div>
                </div>
                <div class="card-body">
                  <h6 class="fw-bold mb-1"><%= product.name %></h6>
                  <p class="text-muted small mb-0">KSh <%= Number(product.price).toLocaleString() %></p>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else if (query) { %>
          <div class="col-12 text-center py-5">
            <i class="bi bi-emoji-frown display-1 text-muted"></i>
            <p class="text-muted mt-3">No products match "<%= query %>"</p>
          </div>
        <% } else { %>
          <div class="col-12 text-center py-5">
            <i class="bi bi-arrow-up-circle display-1 text-muted"></i>
            <p class="text-muted mt-3">Enter a search term above</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
