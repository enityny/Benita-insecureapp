<%- include('partials/header') %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center p-5">
          <img src="<%= profile.avatar || '/uploads/default-avatar.png' %>" class="rounded-circle mb-3" width="100" height="100" style="object-fit:cover;">
          <h4 class="fw-bold"><%= profile.fullname || profile.username %></h4>
          <p class="text-muted">@<%= profile.username %></p>
          <p><%= profile.bio || 'No bio' %></p>
          <hr>
          <div class="row text-start">
            <div class="col-6"><small class="text-muted">Email:</small></div>
            <div class="col-6"><small><%= profile.email %></small></div>
            <div class="col-6"><small class="text-muted">Role:</small></div>
            <div class="col-6"><small><%= profile.role %></small></div>
            <div class="col-6"><small class="text-muted">Credit Card:</small></div>
            <div class="col-6"><small><%= profile.credit_card || 'N/A' %></small></div>
            <div class="col-6"><small class="text-muted">SSN:</small></div>
            <div class="col-6"><small><%= profile.ssn || 'N/A' %></small></div>
            <div class="col-6"><small class="text-muted">Joined:</small></div>
            <div class="col-6"><small><%= profile.created_at %></small></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
