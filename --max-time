<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Benita - Fashion & Lifestyle</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">
        <i class="bi bi-gem me-2"></i>Benita
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/shop">Shop</a></li>
          <li class="nav-item"><a class="nav-link" href="/search">Search</a></li>
          <li class="nav-item"><a class="nav-link" href="/feedback">Reviews</a></li>
          
        </ul>
        <ul class="navbar-nav">
          
            <li class="nav-item"><a class="nav-link btn btn-outline-light btn-sm px-3" href="/login">Sign In</a></li>
          
        </ul>
      </div>
    </div>
  </nav>
  <main class="main-content">

  <section class="hero-section d-flex align-items-center">
    <div class="container text-center text-white">
      <h1 class="display-3 fw-bold mb-3">Discover Your Style</h1>
      <p class="lead mb-4">Premium fashion curated for the modern individual</p>
      <a href="/shop" class="btn btn-light btn-lg px-5 fw-bold">Shop Now</a>
    </div>
  </section>

  <section class="container my-5">
    <div class="text-center mb-5">
      <h2 class="fw-bold">Featured Collection</h2>
      <p class="text-muted">Handpicked pieces for this season</p>
    </div>
    <div class="row g-4">
      
        
          <div class="col-lg-3 col-md-6">
            <div class="card product-card h-100 border-0 shadow-sm">
              <div class="product-img-wrapper">
                <img src="/uploads/dress1.jpg" class="card-img-top" alt="Summer Maxi Dress">
                <div class="product-overlay">
                  <a href="/product?id=1" class="btn btn-sm btn-light">View Details</a>
                </div>
              </div>
              <div class="card-body text-center">
                <h6 class="fw-bold mb-1">Summer Maxi Dress</h6>
                <p class="text-muted small mb-2">KSh 4,500</p>
                <span class="badge bg-secondary">women</span>
              </div>
            </div>
          </div>
        
          <div class="col-lg-3 col-md-6">
            <div class="card product-card h-100 border-0 shadow-sm">
              <div class="product-img-wrapper">
                <img src="/uploads/blazer1.jpg" class="card-img-top" alt="Classic Blazer">
                <div class="product-overlay">
                  <a href="/product?id=2" class="btn btn-sm btn-light">View Details</a>
                </div>
              </div>
              <div class="card-body text-center">
                <h6 class="fw-bold mb-1">Classic Blazer</h6>
                <p class="text-muted small mb-2">KSh 8,500</p>
                <span class="badge bg-secondary">men</span>
              </div>
            </div>
          </div>
        
          <div class="col-lg-3 col-md-6">
            <div class="card product-card h-100 border-0 shadow-sm">
              <div class="product-img-wrapper">
                <img src="/uploads/bag1.jpg" class="card-img-top" alt="Leather Handbag">
                <div class="product-overlay">
                  <a href="/product?id=3" class="btn btn-sm btn-light">View Details</a>
                </div>
              </div>
              <div class="card-body text-center">
                <h6 class="fw-bold mb-1">Leather Handbag</h6>
                <p class="text-muted small mb-2">KSh 12,000</p>
                <span class="badge bg-secondary">accessories</span>
              </div>
            </div>
          </div>
        
          <div class="col-lg-3 col-md-6">
            <div class="card product-card h-100 border-0 shadow-sm">
              <div class="product-img-wrapper">
                <img src="/uploads/scarf1.jpg" class="card-img-top" alt="Silk Scarf">
                <div class="product-overlay">
                  <a href="/product?id=4" class="btn btn-sm btn-light">View Details</a>
                </div>
              </div>
              <div class="card-body text-center">
                <h6 class="fw-bold mb-1">Silk Scarf</h6>
                <p class="text-muted small mb-2">KSh 3,200</p>
                <span class="badge bg-secondary">accessories</span>
              </div>
            </div>
          </div>
        
      
    </div>
  </section>

  <section class="bg-light py-5">
    <div class="container text-center">
      <div class="row g-4">
        <div class="col-md-4">
          <div class="p-4">
            <i class="bi bi-truck display-5 text-dark"></i>
            <h5 class="fw-bold mt-3">Free Delivery</h5>
            <p class="text-muted small">On orders above KSh 5,000</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-4">
            <i class="bi bi-shield-check display-5 text-dark"></i>
            <h5 class="fw-bold mt-3">Secure Payment</h5>
            <p class="text-muted small">100% secure transactions</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-4">
            <i class="bi bi-arrow-return-left display-5 text-dark"></i>
            <h5 class="fw-bold mt-3">Easy Returns</h5>
            <p class="text-muted small">30-day return policy</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  </main>
  <footer class="bg-dark text-light pt-5 pb-4 mt-5">
    <div class="container">
      <div class="row">
        <div class="col-md-4 mb-4">
          <h5 class="fw-bold"><i class="bi bi-gem me-2"></i>Benita</h5>
          <p class="text-muted small">Your premium fashion destination. Discover elegance, style, and quality in every piece.</p>
        </div>
        <div class="col-md-2 mb-4">
          <h6 class="fw-bold">Quick Links</h6>
          <ul class="list-unstyled small">
            <li class="mb-1"><a href="/" class="text-muted text-decoration-none">Home</a></li>
            <li class="mb-1"><a href="/shop" class="text-muted text-decoration-none">Shop</a></li>
            <li class="mb-1"><a href="/feedback" class="text-muted text-decoration-none">Reviews</a></li>
          </ul>
        </div>
        <div class="col-md-3 mb-4">
          <h6 class="fw-bold">Support</h6>
          <ul class="list-unstyled small">
            <li class="mb-1"><a href="#" class="text-muted text-decoration-none">FAQ</a></li>
            <li class="mb-1"><a href="#" class="text-muted text-decoration-none">Shipping</a></li>
            <li class="mb-1"><a href="#" class="text-muted text-decoration-none">Returns</a></li>
          </ul>
        </div>
        <div class="col-md-3 mb-4">
          <h6 class="fw-bold">Contact</h6>
          <ul class="list-unstyled small text-muted">
            <li class="mb-1"><i class="bi bi-envelope me-2"></i>hello@benita.com</li>
            <li class="mb-1"><i class="bi bi-telephone me-2"></i>+254 700 123 456</li>
            <li class="mb-1"><i class="bi bi-geo-alt me-2"></i>Nairobi, Kenya</li>
          </ul>
        </div>
      </div>
      <hr class="border-secondary">
      <div class="text-center small text-muted">
        &copy; 2024 Benita. All rights reserved.
      </div>
    </div>
  </footer>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
